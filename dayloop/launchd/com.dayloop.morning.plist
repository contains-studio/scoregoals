<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.dayloop.morning</string>

    <key>ProgramArguments</key>
    <array>
        <string>__DAYLOOP_BIN__</string>
        <string>plan</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__DAYLOOP_REPO__</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>__DAYLOOP_BINDIR__:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <!-- Morning plan at 07:30 local time, every day. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>7</integer>
        <key>Minute</key>
        <integer>30</integer>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>__HOME__/Library/Logs/dayloop/morning.out.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/Library/Logs/dayloop/morning.err.log</string>
</dict>
</plist>
